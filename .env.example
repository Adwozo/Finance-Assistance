# Copy to .env and adjust as needed.

# SQLAlchemy database URL.
# SQLite (default):  sqlite:///data/transactions.db
# PostgreSQL:        postgresql+psycopg://user:pass@localhost:5432/finance
DATABASE_URL=sqlite:///data/transactions.db

# Folder the app scans for CSV statements (relative to project root or absolute).
STATEMENTS_DIR=statements

# Where SQLite database files live (created on demand).
DATA_DIR=data

# Host/port for the FastAPI dev server.
APP_HOST=127.0.0.1
APP_PORT=8000

# Default currency used when a statement does not specify one.
DEFAULT_CURRENCY=HKD
